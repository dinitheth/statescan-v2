# Blockchain Configuration
WS_ENDPOINT=wss://rpc.polkadot.io
CHAIN=polkadot

# API Endpoints (for frontend)
REACT_APP_PUBLIC_API_END_POINT=http://localhost:5010/
REACT_APP_PUBLIC_GRAPHQL_API_END_POINT=http://localhost:4000/
REACT_APP_PUBLIC_CHAIN=polkadot
REACT_APP_DEFAULT_IPFS_GATEWAY=https://cloudflare-ipfs.com/ipfs/
REACT_APP_PUBLIC_SIMPLE_MODE=true

# Optional: Use browser router instead of hash router
# REACT_APP_BROWSER_ROUTER=1

# Optional: Identity server (if needed)
# REACT_APP_PUBLIC_IDENTITY_SERVER_HOST=https://id.statescan.io